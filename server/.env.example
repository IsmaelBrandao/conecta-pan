# URL do seu projeto Supabase (Settings > API > Project URL)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# SERVICE ROLE KEY (Settings > API > service_role).
# ATENCAO: esta chave so pode viver no servidor, nunca no frontend.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# Porta do servidor (o Render injeta automaticamente)
PORT=3001

# Origem(ns) permitida(s) no CORS, separadas por virgula.
# Em dev: http://localhost:5173  | Em prod: a URL do seu front no Vercel
CLIENT_ORIGIN=http://localhost:5173
